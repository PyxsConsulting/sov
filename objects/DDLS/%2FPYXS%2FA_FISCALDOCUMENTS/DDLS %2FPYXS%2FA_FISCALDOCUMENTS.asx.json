    "AS4DATE":"0000-00-00",
    "AS4TIME":"00:00:00",
    "SOURCE":"@EndUserText.label: 'Input Parameters para FiscalDocuments Sovos'\r\ndefine root abstract entity /PYXS/A_FiscalDocuments\r\n{\r\n      @EndUserText.label: 'Empresa'\r\n      @UI.selectionField: [{position: 1}]\r\n      @Consumption.valueHelpDefinition: [{ entity: {name: 'I_CompanyCode', element: 'CompanyCode'  }}]\r\n      @Consumption.filter: {mandatory: true, selectionType: #SINGLE}\r\n  key COMPANY       : abap.char(4);\r\n      @EndUserText.label: 'Local de Negócio'\r\n      @UI.selectionField: [{position: 2}]\r\n      @Consumption.valueHelpDefinition: [{\r\n      entity        : {name: 'I_BR_BusinessPlace', element: 'Branch'},\r\n      additionalBinding: [{\r\n        localElement: 'COMPANY',\r\n        element     : 'CompanyCode',\r\n        usage       : #FILTER_AND_RESULT\r\n      }]\r\n      }]\r\n      @Consumption.filter: {mandatory: true, selectionType: #SINGLE}\r\n  key BRANCH        : abap.char(4);\r\n      @EndUserText.label: 'Documento'\r\n      @UI.selectionField: [{position: 3}]\r\n      //@Consumption.valueHelpDefinition: [{ entity: {name: 'I_BR_NFDocument', element: 'BR_NotaFiscal'  }}]\r\n      @Consumption.filter.selectionType: #INTERVAL\r\n      @UI.lineItem  : [{ position: 1 }]\r\n  key DOCUMENT      : abap.numc(10);\r\n      @EndUserText.label: 'Data Lançamento De'\r\n      @UI.selectionField: [{position: 4}]\r\n      @Consumption.filter.selectionType: #INTERVAL\r\n      posting_low   : abap.dats;\r\n      @EndUserText.label: 'Data Lançamento Até'\r\n      @UI.selectionField: [{position: 5}]\r\n      @Consumption.filter.selectionType: #INTERVAL\r\n      posting_high  : abap.dats;\r\n      @EndUserText.label: 'Data de Criação De'\r\n      @UI.selectionField: [{position: 6}]\r\n      @Consumption.filter.selectionType: #INTERVAL\r\n      CREATION_low  : abap.dats;\r\n      @EndUserText.label: 'Data de Criação Até'\r\n      @UI.selectionField: [{position: 7}]\r\n      @Consumption.filter.selectionType: #INTERVAL\r\n      CREATION_high : abap.dats;\r\n      @EndUserText.label: 'Categoria de NF'\r\n      @UI.selectionField: [{position: 8}]\r\n      @Consumption.filter.selectionType: #INTERVAL\r\n      //@Consumption.valueHelpDefinition: [{ entity: {name: 'I_BR_NFDocumentType', element: 'BR_NFDocumentType'  }}]\r\n      NFtype        : abap.char(2);\r\n}\r\n/*+[internal] {\n\"BASEINFO\":\n{\n\"FROM\":\n[],\n\"ASSOCIATED\":\n[],\n\"BASE\":\n[],\n\"ANNO_REF\":\n[],\n\"SCALAR_FUNCTION\":\n[],\n\"VERSION\":0,\n\"ANNOREF_EVALUATION_ERROR\":\"\"\n}\n}*/",
